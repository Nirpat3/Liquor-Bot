# Mississippi DOR Order Bot - Copy this to .env and fill in your credentials
# cp .env.example .env

SITE_USERNAME=your_username
SITE_PASSWORD=your_password
SITE_URL=https://tap.dor.ms.gov/
HEADLESS=False

# Optional: Webhook for order notifications (Discord, Slack, or any URL)
# WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
