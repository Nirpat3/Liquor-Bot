# Mississippi DOR Order Bot - Copy this to .env and fill in your credentials
# cp .env.example .env

SITE_USERNAME=your_username
SITE_PASSWORD=your_password
SITE_URL=https://tap.dor.ms.gov/
HEADLESS=False

# Optional: Webhook for order notifications (Discord, Slack, or any URL)
# WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# RapidRMS API (Sales Intelligence tab)
# RAPIDRMS_CLIENT_ID=your_client_id
# RAPIDRMS_USERNAME=your_rapidrms_username
# RAPIDRMS_PASSWORD=your_rapidrms_password
# RAPIDRMS_SOURCE=RapidRMS

# Data source: "direct" (RapidRMS API) or "cortex" (CortexDB)
# DATA_SOURCE=direct

# Shre AI (optional - AI-powered order recommendations)
# SHRE_API_URL=https://127.0.0.1:5497

# Shre Predict (optional - cloud intelligence with workspace isolation)
# SHRE_PREDICT_URL=http://127.0.0.1:5487
# DOR_WORKSPACE=store-123
